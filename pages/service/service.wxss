page {
  background-color: #f5f5f5;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.service-info {
  flex: 1;
}

.service-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 26rpx;
  color: #999;
}

.service-action {
  margin-left: 24rpx;
}

.btn-text {
  color: #07c160;
  font-size: 28rpx;
  font-weight: 500;
}
