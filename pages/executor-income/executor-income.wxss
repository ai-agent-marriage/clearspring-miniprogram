/* 清如 ClearSpring - 收入管理页样式 */

.container {
  padding: var(--spacing-2);
  padding-bottom: var(--spacing-4);
  background: linear-gradient(180deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  min-height: 100vh;
}

/* ========== 总收入卡片 ========== */
.income-card {
  padding: var(--spacing-3);
  margin-bottom: var(--spacing-2);
  background: linear-gradient(135deg, var(--green-main) 0%, var(--green-dim) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  text-align: center;
  color: #fff;
}

.income-label {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: var(--spacing-1);
}

.income-amount {
  display: block;
  font-size: 80rpx;
  font-weight: 700;
  margin-bottom: var(--spacing-3);
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.income-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: var(--spacing-2);
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.btn-withdraw {
  width: 100%;
  background: rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  color: #fff;
}

.btn-withdraw:active {
  background: rgba(255, 255, 255, 0.2);
}

.btn-withdraw.disabled {
  opacity: 0.4;
}

/* ========== 数据概览 ========== */
.overview-section {
  margin-bottom: var(--spacing-2);
}

.section-tabs {
  display: flex;
  gap: var(--spacing-2);
  margin-bottom: var(--spacing-2);
}

.tab-item {
  flex: 1;
  padding: var(--spacing-1);
  text-align: center;
  background: rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-dim);
  transition: all var(--transition-base);
}

.tab-item:active {
  opacity: 0.7;
}

.tab-item.active {
  background: var(--green-main);
  color: #fff;
  font-weight: 600;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-1);
  padding: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-1);
}

.overview-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--green-main);
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 22rpx;
  color: var(--text-dim);
  text-align: center;
}

/* ========== 财务明细 ========== */
.detail-section {
  margin-bottom: var(--spacing-2);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-2);
  padding: 0 var(--spacing-1);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.filter-actions {
  display: flex;
  gap: var(--spacing-2);
}

.filter-text {
  font-size: 26rpx;
  color: var(--green-main);
}

.detail-list {
  min-height: 300rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-4);
  background: rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-lg);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-2);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-dim);
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-2);
  margin-bottom: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  transition: all var(--transition-base);
}

.transaction-item:active {
  transform: scale(0.98);
}

.transaction-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.transaction-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: var(--spacing-2);
  flex-shrink: 0;
}

.transaction-icon.income {
  background: rgba(0, 138, 23, 0.1);
}

.transaction-icon.withdraw {
  background: rgba(74, 93, 78, 0.1);
}

.transaction-icon.refund {
  background: rgba(186, 26, 26, 0.1);
}

.transaction-info {
  display: flex;
  flex-direction: column;
}

.transaction-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  margin-bottom: 4rpx;
}

.transaction-time {
  font-size: 24rpx;
  color: var(--text-dim);
}

.transaction-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.transaction-amount {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.transaction-amount.positive {
  color: var(--success);
}

.transaction-amount.negative {
  color: var(--error-soft);
}

.transaction-status {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
}

.transaction-status.pending {
  background: rgba(255, 154, 68, 0.1);
  color: var(--warning);
}

.transaction-status.completed {
  background: rgba(0, 138, 23, 0.1);
  color: var(--success);
}

.transaction-status.failed {
  background: rgba(186, 26, 26, 0.1);
  color: var(--error-soft);
}

/* ========== 加载状态 ========== */
.loading-state,
.no-more-state {
  padding: var(--spacing-3);
  text-align: center;
}

.loading-text,
.no-more-text {
  font-size: 26rpx;
  color: var(--text-dim);
}
