/* pages/merit-forest/merit-forest.wxss */

.container {
  padding: var(--spacing-2);
  padding-bottom: calc(var(--spacing-2) + env(safe-area-inset-bottom));
}

/* ========== 顶部功德统计 ========== */

.merit-header {
  margin-bottom: var(--spacing-3);
}

.merit-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(135deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-3);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  line-height: 1.2;
  background: linear-gradient(135deg, var(--gold-main) 0%, var(--gold-dim) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-dim);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: linear-gradient(180deg, transparent 0%, var(--gold-main) 50%, transparent 100%);
  margin: 0 var(--spacing-1);
}

/* ========== 章节标题 ========== */

.section-header {
  margin: var(--spacing-3) 0 var(--spacing-2);
  text-align: center;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
}

/* ========== 证书墙瀑布流 ========== */

.certificate-wall {
  display: flex;
  gap: var(--spacing-2);
  margin-bottom: var(--spacing-3);
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2);
}

.certificate-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: var(--spacing-2);
  box-shadow: 0 8rpx 32rpx rgba(212, 184, 123, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: transform var(--transition-base);
}

.certificate-card:active {
  transform: scale(0.98);
}

.cert-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-1);
  padding-bottom: var(--spacing-1);
  border-bottom: 1rpx solid rgba(212, 184, 123, 0.2);
}

.cert-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gold-dim);
}

.cert-number {
  font-size: 20rpx;
  color: var(--text-dim);
}

.cert-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: var(--spacing-1);
}

.cert-text {
  font-size: 24rpx;
  color: var(--text-main);
  line-height: 1.6;
}

.cert-text.highlight {
  color: var(--gold-dim);
  font-weight: 500;
}

.cert-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--spacing-1);
  border-top: 1rpx solid rgba(212, 184, 123, 0.2);
}

.cert-seal {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gold-dim);
  background: rgba(212, 184, 123, 0.1);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
}

.cert-date {
  font-size: 20rpx;
  color: var(--text-dim);
}

/* ========== 历史放生记录 ========== */

.history-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2);
}

.history-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-2);
  background: linear-gradient(180deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  border-radius: var(--radius-md);
  transition: all var(--transition-base);
}

.history-item:active {
  opacity: 0.8;
}

.history-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--gold-main) 0%, var(--gold-dim) 100%);
  border-radius: var(--radius-md);
  margin-right: var(--spacing-2);
  flex-shrink: 0;
}

.date-day {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.date-month {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.history-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
}

.history-location {
  font-size: 24rpx;
  color: var(--text-dim);
}

.history-count {
  font-size: 24rpx;
  color: var(--gold-dim);
  font-weight: 500;
}

.history-action {
  margin-left: var(--spacing-1);
}

.action-icon {
  font-size: 40rpx;
  color: var(--text-dim);
  line-height: 1;
}

/* ========== 证书预览弹窗 ========== */

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: var(--spacing-2);
}

.modal-content {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-2);
  border-bottom: 1rpx solid rgba(212, 184, 123, 0.2);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-dim);
  line-height: 1;
  padding: 8rpx;
}

.modal-body {
  padding: var(--spacing-3);
}

.preview-certificate {
  background: linear-gradient(135deg, #fff 0%, var(--bg-xuan-light) 100%);
  border-radius: var(--radius-md);
  padding: var(--spacing-3);
  border: 2rpx solid var(--gold-main);
}

.preview-header {
  text-align: center;
  margin-bottom: var(--spacing-3);
  padding-bottom: var(--spacing-2);
  border-bottom: 2rpx solid var(--gold-main);
}

.preview-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--gold-dim);
  margin-bottom: 8rpx;
}

.preview-number {
  display: block;
  font-size: 20rpx;
  color: var(--text-dim);
}

.preview-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  text-align: center;
  margin-bottom: var(--spacing-3);
}

.preview-text {
  font-size: 28rpx;
  color: var(--text-main);
}

.preview-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--gold-dim);
  margin: 8rpx 0;
}

.preview-count {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gold-main);
}

.preview-blessing {
  font-size: 28rpx;
  color: var(--text-dim);
  margin-top: var(--spacing-1);
  font-style: italic;
}

.preview-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--spacing-2);
  border-top: 2rpx solid var(--gold-main);
}

.preview-seal {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gold-dim);
  background: rgba(212, 184, 123, 0.2);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-sm);
}

.preview-date {
  font-size: 24rpx;
  color: var(--text-dim);
}

.modal-actions {
  padding: var(--spacing-2);
  padding-bottom: calc(var(--spacing-2) + env(safe-area-inset-bottom));
}

.modal-actions .btn {
  width: 100%;
}
