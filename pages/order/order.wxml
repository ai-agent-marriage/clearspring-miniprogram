<view class="container">
  <view class="card">
    <view class="section-title">我的订单</view>
    <view class="order-list" wx:if="{{orders.length > 0}}">
      <view class="order-card" wx:for="{{orders}}" wx:key="id">
        <view class="order-header">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-status {{item.statusClass}}">{{item.status}}</text>
        </view>
        <view class="order-body">
          <text class="order-service">{{item.serviceName}}</text>
          <text class="order-date">{{item.createTime}}</text>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-text">暂无订单</text>
    </view>
  </view>
</view>
