page {
  background-color: #f5f5f5;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-status.pending {
  color: #ff9900;
}

.order-status.completed {
  color: #07c160;
}

.order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-service {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.order-date {
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
