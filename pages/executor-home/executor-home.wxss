/* 清如 ClearSpring - 执行者首页样式 */

.container {
  padding: var(--spacing-2);
  padding-bottom: var(--spacing-4);
  background: linear-gradient(180deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  min-height: 100vh;
}

/* ========== 顶部状态栏 ========== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-2);
  margin-bottom: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
}

.header-left {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
}

.status-tag.verified {
  background: rgba(0, 138, 23, 0.1);
  color: var(--success);
}

.status-tag.pending {
  background: rgba(255, 154, 68, 0.1);
  color: var(--warning);
}

.status-tag.unverified {
  background: rgba(186, 26, 26, 0.1);
  color: var(--error-soft);
}

.header-right {
  position: relative;
  padding: var(--spacing-1);
}

.notification-icon {
  font-size: 40rpx;
}

.notification-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--error-soft);
  border-radius: 50%;
  border: 2rpx solid #fff;
}

/* ========== 快捷入口 ========== */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-2);
  margin-bottom: var(--spacing-2);
}

.action-card {
  padding: var(--spacing-3);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all var(--transition-base);
}

.action-card:active {
  transform: scale(0.98);
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: var(--spacing-1);
}

.action-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--green-main);
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-dim);
}

/* ========== 数据区域 ========== */
.stats-section {
  padding: var(--spacing-2);
  margin-bottom: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: var(--spacing-2);
  padding-left: var(--spacing-1);
  border-left: 6rpx solid var(--green-main);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-1);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--green-main);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-dim);
  text-align: center;
}

/* ========== 进行中任务 ========== */
.ongoing-section {
  margin-bottom: var(--spacing-2);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-2);
  padding: 0 var(--spacing-1);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.section-more {
  font-size: 26rpx;
  color: var(--green-main);
}

.ongoing-list {
  min-height: 300rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-4);
  background: rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-lg);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-2);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-dim);
  margin-bottom: var(--spacing-3);
}

.btn-go-order {
  min-width: 200rpx;
}

.task-card {
  padding: var(--spacing-2);
  margin-bottom: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  transition: all var(--transition-base);
}

.task-card:active {
  transform: scale(0.98);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-1);
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  flex: 1;
}

.task-status {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  margin-left: var(--spacing-1);
}

.task-status.processing {
  background: rgba(74, 93, 78, 0.1);
  color: var(--green-main);
}

.task-status.pending {
  background: rgba(255, 154, 68, 0.1);
  color: var(--warning);
}

.task-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: var(--spacing-1);
}

.task-location,
.task-time {
  font-size: 26rpx;
  color: var(--text-dim);
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--spacing-1);
  border-top: 1rpx solid rgba(74, 93, 78, 0.1);
}

.task-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--green-main);
}

.task-deadline {
  font-size: 24rpx;
  color: var(--text-dim);
}

/* ========== 公告区域 ========== */
.notice-section {
  padding: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  border-left: 6rpx solid var(--warning);
}

.notice-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-1);
}

.notice-icon {
  font-size: 32rpx;
  margin-right: var(--spacing-1);
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.notice-content {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.6;
}
