/* pages/wiki/wiki.wxss */

.container {
  padding: var(--spacing-2);
  padding-bottom: calc(var(--spacing-2) + env(safe-area-inset-bottom));
}

/* ========== 顶部标题 ========== */

.wiki-header {
  text-align: center;
  margin-bottom: var(--spacing-3);
  padding: var(--spacing-3) 0;
}

.wiki-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.wiki-subtitle {
  display: block;
  font-size: 28rpx;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  color: var(--text-dim);
  font-style: italic;
}

/* ========== 章节样式 ========== */

.section {
  margin-bottom: var(--spacing-3);
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-2);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  color: var(--text-main);
}

.section-badge {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  margin-left: var(--spacing-1);
  background: linear-gradient(135deg, var(--gold-main) 0%, var(--gold-dim) 100%);
  color: #fff;
}

.section-badge.warning {
  background: linear-gradient(135deg, #FF9A44 0%, #FF6B35 100%);
}

.section-badge.success {
  background: linear-gradient(135deg, var(--success) 0%, #006611 100%);
}

/* ========== 物种列表 ========== */

.species-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2);
}

.species-item {
  display: flex;
  padding: var(--spacing-2);
  background: linear-gradient(180deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  border-radius: var(--radius-md);
  transition: all var(--transition-base);
}

.species-item:active {
  opacity: 0.8;
  transform: scale(0.99);
}

.species-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  margin-right: var(--spacing-2);
  background: linear-gradient(135deg, var(--bg-xuan-light) 0%, var(--bg-xuan) 100%);
}

.species-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: var(--spacing-1) 0;
}

.species-header {
  margin-bottom: 8rpx;
}

.species-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  color: var(--text-main);
  margin-bottom: 4rpx;
}

.species-latin {
  display: block;
  font-size: 20rpx;
  font-style: italic;
  color: var(--text-dim);
  font-family: 'Times New Roman', serif;
}

.species-desc {
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.6;
  margin-bottom: var(--spacing-1);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.species-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  background: rgba(212, 184, 123, 0.15);
  color: var(--gold-dim);
}

.tag-primary {
  background: linear-gradient(135deg, var(--gold-main) 0%, var(--gold-dim) 100%);
  color: #fff;
}

/* ========== 放生禁忌 ========== */

.taboo-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2);
}

.taboo-item {
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-2);
  background: linear-gradient(180deg, #FFF5F5 0%, #FFF0F0 100%);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--error-soft);
}

.taboo-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-2);
  flex-shrink: 0;
}

.taboo-content {
  flex: 1;
}

.taboo-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  color: var(--error-soft);
  margin-bottom: 8rpx;
}

.taboo-desc {
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.6;
}

/* ========== 推荐水域 ========== */

.water-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2);
}

.water-item {
  padding: var(--spacing-2);
  background: linear-gradient(180deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  border-radius: var(--radius-md);
  transition: all var(--transition-base);
}

.water-item:active {
  opacity: 0.8;
}

.water-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-1);
}

.water-name {
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  color: var(--text-main);
}

.water-distance {
  font-size: 24rpx;
  color: var(--text-dim);
}

.water-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.6;
  margin-bottom: var(--spacing-1);
}

.water-features {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.feature {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  background: rgba(74, 93, 78, 0.1);
  color: var(--green-main);
}

/* ========== 生态说明 ========== */

.ecology-card {
  margin-bottom: var(--spacing-2);
  overflow: hidden;
}

.ecology-content {
  padding: var(--spacing-2);
}

.ecology-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
  color: var(--text-main);
  margin-bottom: var(--spacing-1);
}

.ecology-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.8;
  font-family: 'Songti SC', 'STSong', 'SimSun', serif;
}

.ecology-illustration {
  width: 100%;
  height: auto;
  margin-top: var(--spacing-2);
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, var(--bg-xuan-light) 0%, var(--bg-xuan) 100%);
}
