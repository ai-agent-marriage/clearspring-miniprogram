/* 清如 ClearSpring - 任务助手页样式 */

.container {
  padding: var(--spacing-2);
  padding-bottom: var(--spacing-4);
  background: linear-gradient(180deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  min-height: 100vh;
}

/* ========== 当前任务状态 ========== */
.current-task-section {
  padding: var(--spacing-2);
  margin-bottom: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
}

.task-status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-2);
  padding-bottom: var(--spacing-2);
  border-bottom: 1rpx solid rgba(74, 93, 78, 0.1);
}

.status-label {
  font-size: 28rpx;
  color: var(--text-dim);
}

.status-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--green-main);
}

.status-value.processing {
  color: var(--green-main);
}

.status-value.pending {
  color: var(--warning);
}

.status-value.completed {
  color: var(--success);
}

/* 任务进度 */
.task-progress {
  padding: var(--spacing-2) 0;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-1);
}

.task-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.task-progress-text {
  font-size: 26rpx;
  color: var(--green-main);
  font-weight: 500;
}

.progress-bar {
  height: 12rpx;
  background: rgba(74, 93, 78, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: var(--spacing-2);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--green-main) 0%, var(--success) 100%);
  border-radius: 6rpx;
  transition: width var(--transition-slow);
}

.task-actions {
  display: flex;
  gap: var(--spacing-2);
}

.btn-small {
  flex: 1;
  min-height: 72rpx;
  font-size: 26rpx;
}

/* 无任务状态 */
.no-task {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-3);
}

.no-task-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-2);
}

.no-task-text {
  font-size: 28rpx;
  color: var(--text-dim);
  margin-bottom: var(--spacing-3);
}

/* ========== 快捷导航 ========== */
.navigation-section {
  margin-bottom: var(--spacing-2);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: var(--spacing-2);
  padding-left: var(--spacing-1);
  border-left: 6rpx solid var(--green-main);
}

.nav-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-2);
}

.nav-item {
  padding: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: all var(--transition-base);
}

.nav-item:active {
  transform: scale(0.98);
}

.nav-icon {
  font-size: 48rpx;
  margin-bottom: var(--spacing-1);
}

.nav-text {
  font-size: 24rpx;
  color: var(--text-main);
}

/* ========== 常用功能 ========== */
.quick-functions-section {
  margin-bottom: var(--spacing-2);
}

.function-list {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.function-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-2);
  border-bottom: 1rpx solid rgba(74, 93, 78, 0.1);
  transition: all var(--transition-base);
}

.function-item:last-of-type {
  border-bottom: none;
}

.function-item:active {
  background: rgba(74, 93, 78, 0.05);
}

.function-icon {
  font-size: 44rpx;
  margin-right: var(--spacing-2);
}

.function-info {
  flex: 1;
}

.function-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  margin-bottom: 4rpx;
}

.function-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
}

.function-arrow {
  font-size: 36rpx;
  color: var(--text-dim);
}

/* ========== 提示信息 ========== */
.tips-section {
  padding: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  border-left: 6rpx solid var(--info);
}

.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-1);
}

.tips-icon {
  font-size: 32rpx;
  margin-right: var(--spacing-1);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.tips-content {
  display: block;
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.6;
}

/* ========== 按钮样式 ========== */
.btn-outline {
  min-height: 72rpx;
  background: transparent;
  border: 2rpx solid var(--green-main);
  color: var(--green-main);
  border-radius: var(--radius-md);
  font-size: 26rpx;
}

.btn-outline:active {
  background: rgba(74, 93, 78, 0.1);
}
