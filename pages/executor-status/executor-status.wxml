<!-- 清如 ClearSpring - 执行者审核状态页 -->
<view class="container">
  <!-- 状态卡片 -->
  <view class="status-card glass">
    <view class="status-icon {{statusClass}}">
      <text wx:if="{{auditStatus === 'pending'}}">⏳</text>
      <text wx:elif="{{auditStatus === 'approved'}}">✓</text>
      <text wx:elif="{{auditStatus === 'rejected'}}">!</text>
      <text wx:elif="{{auditStatus === 'need补充'}}">📝</text>
    </view>
    
    <view class="status-info">
      <text class="status-title">{{statusTitle}}</text>
      <text class="status-desc">{{statusDesc}}</text>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-section">
    <view class="progress-bar">
      <view class="progress-track">
        <view class="progress-fill {{auditStatus === 'approved' ? 'completed' : ''}}" style="width: {{progressPercent}}%"></view>
      </view>
      <view class="progress-steps">
        <view class="progress-step {{currentStep >= 1 ? 'active' : ''}}">
          <view class="step-dot"></view>
          <text class="step-text">提交</text>
        </view>
        <view class="progress-step {{currentStep >= 2 ? 'active' : ''}}">
          <view class="step-dot"></view>
          <text class="step-text">审核</text>
        </view>
        <view class="progress-step {{currentStep >= 3 ? 'active' : ''}}">
          <view class="step-dot"></view>
          <text class="step-text">完成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 审核详情 -->
  <view class="detail-section glass" wx:if="{{auditStatus === 'rejected' || auditStatus === 'need 补充'}}">
    <view class="detail-header">
      <text class="detail-title">审核意见</text>
      <text class="detail-time">{{auditTime}}</text>
    </view>
    
    <view class="detail-content">
      <text class="detail-text">{{rejectReason}}</text>
    </view>
    
    <view class="detail-actions">
      <button class="btn btn-green" bindtap="onModify">修改重新提交</button>
    </view>
  </view>

  <!-- 审核通过提示 -->
  <view class="success-section glass" wx:if="{{auditStatus === 'approved'}}">
    <view class="success-icon">🎉</view>
    <text class="success-title">恭喜您通过审核！</text>
    <text class="success-desc">您已成为认证执行者，可以开始接单了</text>
    <button class="btn btn-green btn-start" bindtap="onStartOrder">开始接单</button>
  </view>

  <!-- 审核中提示 -->
  <view class="pending-section" wx:if="{{auditStatus === 'pending'}}">
    <view class="pending-tip">
      <text class="tip-icon">ℹ️</text>
      <text class="tip-text">审核将在 1-3 个工作日内完成，请耐心等待</text>
    </view>
    
    <view class="pending-actions">
      <button class="btn btn-outline" bindtap="onContactService">联系客服</button>
      <button class="btn btn-outline" bindtap="onRefresh">刷新状态</button>
    </view>
  </view>

  <!-- 时间线 -->
  <view class="timeline-section glass">
    <view class="timeline-title">审核记录</view>
    
    <view class="timeline-list">
      <view class="timeline-item" wx:for="{{timeline}}" wx:key="id">
        <view class="timeline-dot {{item.status}}"></view>
        <view class="timeline-content">
          <text class="timeline-event">{{item.event}}</text>
          <text class="timeline-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
