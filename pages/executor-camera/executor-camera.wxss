/* 清如 ClearSpring - 原生拍摄页样式 */

.container {
  width: 100%;
  height: 100vh;
  background: #000;
  position: relative;
  overflow: hidden;
}

/* ========== 相机区域 ========== */
.camera-section {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 300rpx;
  background: #000;
}

.camera-view {
  width: 100%;
  height: 100%;
}

.camera-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-2);
}

.placeholder-text {
  font-size: 28rpx;
  color: #fff;
}

/* 拍摄提示遮罩 */
.camera-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.overlay-frame {
  width: 500rpx;
  height: 500rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-md);
  box-shadow: 0 0 0 9999rpx rgba(0, 0, 0, 0.5);
}

.overlay-tip {
  margin-top: var(--spacing-2);
  font-size: 26rpx;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

/* ========== 控制区域 ========== */
.control-section {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-2);
  padding-bottom: calc(var(--spacing-2) + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

/* 模式选择 */
.mode-selector {
  display: flex;
  justify-content: center;
  gap: var(--spacing-3);
  margin-bottom: var(--spacing-2);
}

.mode-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-1) var(--spacing-2);
  transition: all var(--transition-base);
}

.mode-item:active {
  opacity: 0.7;
}

.mode-item.active .mode-icon {
  transform: scale(1.2);
}

.mode-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  transition: all var(--transition-base);
}

.mode-text {
  font-size: 24rpx;
  color: var(--text-dim);
}

.mode-item.active .mode-text {
  color: var(--green-main);
  font-weight: 600;
}

/* 拍摄按钮区域 */
.capture-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--spacing-2);
}

.capture-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-base);
}

.capture-btn:active {
  transform: scale(0.95);
}

.capture-btn.capturing {
  background: var(--green-main);
  border-color: var(--green-dim);
}

.capture-inner {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid var(--green-main);
  transition: all var(--transition-base);
}

.capture-btn.capturing .capture-inner {
  width: 60rpx;
  height: 60rpx;
  background: var(--green-main);
}

.capture-tip {
  margin-top: var(--spacing-1);
  font-size: 24rpx;
  color: var(--text-dim);
}

/* 功能选项 */
.options-row {
  display: flex;
  justify-content: space-around;
  padding: var(--spacing-1) 0;
}

.option-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-1);
  transition: all var(--transition-base);
}

.option-item:active {
  opacity: 0.7;
}

.option-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.option-text {
  font-size: 22rpx;
  color: var(--text-dim);
}

/* ========== 预览弹窗 ========== */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.preview-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  overflow: hidden;
  animation: modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.preview-image {
  width: 100%;
  max-height: 800rpx;
  background: #000;
}

.preview-actions {
  display: flex;
  gap: var(--spacing-2);
  padding: var(--spacing-2);
}

.btn-retake,
.btn-confirm {
  flex: 1;
}

.btn-outline {
  min-height: 88rpx;
  background: transparent;
  border: 2rpx solid var(--green-main);
  color: var(--green-main);
  border-radius: var(--radius-md);
  font-size: 28rpx;
}

.btn-outline:active {
  background: rgba(74, 93, 78, 0.1);
}

/* ========== 提示框 ========== */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  padding: var(--spacing-2) var(--spacing-3);
  border-radius: var(--radius-md);
  z-index: 2000;
  animation: fadeInOut 2s ease-in-out;
}

.toast-text {
  font-size: 28rpx;
  color: #fff;
}

@keyframes fadeInOut {
  0% { opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}
