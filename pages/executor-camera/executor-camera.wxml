<!-- 清如 ClearSpring - 原生拍摄页 -->
<view class="container">
  <!-- 相机预览区域 -->
  <view class="camera-section">
    <camera 
      wx:if="{{showCamera}}"
      id="camera"
      class="camera-view"
      mode="scanCode"
      resolution="high"
      flash="off"
      bindstop="onCameraStop"
      binderror="onCameraError"
    ></camera>
    
    <view wx:else class="camera-placeholder">
      <text class="placeholder-icon">📷</text>
      <text class="placeholder-text">相机未启动</text>
    </view>
    
    <!-- 拍摄提示遮罩 -->
    <view class="camera-overlay">
      <view class="overlay-frame"></view>
      <text class="overlay-tip">请将凭证完整放入框内</text>
    </view>
  </view>

  <!-- 控制区域 -->
  <view class="control-section glass">
    <!-- 拍摄模式选择 -->
    <view class="mode-selector">
      <view 
        class="mode-item {{currentMode === 'photo' ? 'active' : ''}}"
        bindtap="onSwitchMode"
        data-mode="photo"
      >
        <text class="mode-icon">📷</text>
        <text class="mode-text">拍照</text>
      </view>
      
      <view 
        class="mode-item {{currentMode === 'video' ? 'active' : ''}}"
        bindtap="onSwitchMode"
        data-mode="video"
      >
        <text class="mode-icon">🎥</text>
        <text class="mode-text">录像</text>
      </view>
    </view>

    <!-- 拍摄按钮 -->
    <view class="capture-area">
      <view 
        class="capture-btn {{isCapturing ? 'capturing' : ''}}"
        catchtap="onCapture"
      >
        <view class="capture-inner"></view>
      </view>
      <text class="capture-tip">{{currentMode === 'photo' ? '点击拍照' : '长按录像'}}</text>
    </view>

    <!-- 功能选项 -->
    <view class="options-row">
      <view class="option-item" bindtap="onToggleFlash">
        <text class="option-icon">{{flashOn ? '⚡️' : '⚡'}}</text>
        <text class="option-text">{{flashOn ? '闪光灯开' : '闪光灯关'}}</text>
      </view>
      
      <view class="option-item" bindtap="onSwitchCamera">
        <text class="option-icon">🔄</text>
        <text class="option-text">切换镜头</text>
      </view>
      
      <view class="option-item" bindtap="onGridToggle">
        <text class="option-icon">{{showGrid ? '▦' : '▢'}}</text>
        <text class="option-text">{{showGrid ? '网格开' : '网格关'}}</text>
      </view>
    </view>
  </view>

  <!-- 预览确认弹窗 -->
  <view wx:if="{{showPreview}}" class="preview-modal" catchtap="onModalBackdropTap">
    <view class="preview-content" catchtap="onModalContentTap">
      <image class="preview-image" src="{{previewImage}}" mode="aspectFit" />
      
      <view class="preview-actions">
        <button class="btn btn-outline btn-retake" bindtap="onRetake">重拍</button>
        <button class="btn btn-green btn-confirm" bindtap="onConfirmUse">确认使用</button>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="toast" wx:if="{{toast}}">
    <text class="toast-text">{{toast}}</text>
  </view>
</view>
