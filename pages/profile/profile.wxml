<view class="container">
  <!-- 用户信息卡片 -->
  <view class="card profile-card">
    <view class="user-info">
      <image class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
      <view class="user-details">
        <text class="nickname">{{nickname || '点击登录'}}</text>
        <text class="user-id" wx:if="{{userId}}">ID: {{userId}}</text>
      </view>
    </view>
    <button class="login-btn" wx:if="{{!hasUserInfo}}" bindtap="login">登录/注册</button>
  </view>

  <!-- 功能列表 -->
  <view class="card">
    <view class="menu-list">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="navigateTo">
        <text class="menu-name">{{item.name}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="card">
    <view class="menu-list">
      <view class="menu-item" bindtap="contactUs">
        <text class="menu-name">联系客服</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="aboutUs">
        <text class="menu-name">关于我们</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>
</view>
