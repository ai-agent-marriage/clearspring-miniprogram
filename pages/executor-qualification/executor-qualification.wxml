<!-- 清如 ClearSpring - 执行者资质审核页 -->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">执行者资质审核</text>
    <text class="page-subtitle">完成实名认证，开启接单权限</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 基本信息 -->
    <view class="form-group">
      <view class="form-group-title">基本信息</view>
      
      <view class="form-item">
        <text class="form-label">真实姓名 <text class="required">*</text></text>
        <input 
          class="form-input" 
          placeholder="请输入真实姓名" 
          value="{{realName}}"
          bindinput="onRealNameInput"
          maxlength="20"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">身份证号 <text class="required">*</text></text>
        <input 
          class="form-input" 
          placeholder="请输入 18 位身份证号" 
          value="{{idCard}}"
          bindinput="onIdCardInput"
          maxlength="18"
          type="idcard"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">手机号码 <text class="required">*</text></text>
        <input 
          class="form-input" 
          placeholder="请输入手机号码" 
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
          type="number"
        />
      </view>
    </view>

    <!-- 资质证明 -->
    <view class="form-group">
      <view class="form-group-title">资质证明</view>
      
      <view class="form-item">
        <text class="form-label">身份证正面 <text class="required">*</text></text>
        <view class="upload-area" bindtap="onUploadIdCardFront">
          <image wx:if="{{idCardFront}}" class="upload-image" src="{{idCardFront}}" mode="aspectFill" />
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">+</text>
            <text class="upload-text">上传正面</text>
          </view>
        </view>
      </view>
      
      <view class="form-item">
        <text class="form-label">身份证反面 <text class="required">*</text></text>
        <view class="upload-area" bindtap="onUploadIdCardBack">
          <image wx:if="{{idCardBack}}" class="upload-image" src="{{idCardBack}}" mode="aspectFill" />
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">+</text>
            <text class="upload-text">上传反面</text>
          </view>
        </view>
      </view>
      
      <view class="form-item">
        <text class="form-label">手持身份证 <text class="required">*</text></text>
        <view class="upload-area" bindtap="onUploadHandheld">
          <image wx:if="{{handheld}}" class="upload-image" src="{{handheld}}" mode="aspectFill" />
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">+</text>
            <text class="upload-text">上传手持照</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 技能认证 -->
    <view class="form-group">
      <view class="form-group-title">技能认证</view>
      
      <view class="form-item">
        <text class="form-label">擅长领域</text>
        <picker 
          class="picker" 
          mode="selector" 
          range="{{skillOptions}}" 
          value="{{skillIndex}}"
          bindchange="onSkillChange"
        >
          <view class="picker-value">
            {{skillOptions[skillIndex] || '请选择擅长领域'}}
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="form-label">相关证书（可选）</text>
        <view class="upload-area upload-area-multi" bindtap="onUploadCertificates">
          <view class="upload-list" wx:if="{{certificates.length > 0}}">
            <image wx:for="{{certificates}}" wx:key="*this" class="upload-image-small" src="{{item}}" mode="aspectFill" />
          </view>
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">+</text>
            <text class="upload-text">上传证书</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 服务协议 -->
    <view class="form-group">
      <view class="agreement-item" bindtap="onAgreementToggle">
        <view class="checkbox {{agreementAccepted ? 'checked' : ''}}">
          <text wx:if="{{agreementAccepted}}" class="checkmark">✓</text>
        </view>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" bindtap="onViewAgreement">《执行者服务协议》</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button 
      class="btn btn-green btn-submit {{canSubmit ? '' : 'disabled'}}"
      disabled="{{!canSubmit}}"
      bindtap="onSubmit"
    >
      {{submitting ? '提交中...' : '提交审核'}}
    </button>
    <text class="submit-tip">审核将在 1-3 个工作日内完成</text>
  </view>
</view>
