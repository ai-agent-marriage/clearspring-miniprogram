/* 清如 ClearSpring - 抢单大厅样式 */

.container {
  padding: var(--spacing-2);
  padding-bottom: var(--spacing-4);
  background: linear-gradient(180deg, var(--bg-xuan) 0%, var(--bg-xuan-light) 100%);
  min-height: 100vh;
}

/* ========== 筛选栏 ========== */
.filter-bar {
  display: flex;
  justify-content: space-between;
  padding: var(--spacing-2);
  margin-bottom: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
}

.filter-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-1) var(--spacing-2);
  transition: all var(--transition-base);
}

.filter-item:active {
  opacity: 0.7;
}

.filter-text {
  font-size: 28rpx;
  color: var(--text-main);
  margin-right: 8rpx;
}

.filter-arrow {
  font-size: 20rpx;
  color: var(--text-dim);
}

/* ========== 订单列表 ========== */
.order-list {
  min-height: 500rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-4);
  background: rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-lg);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-2);
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-main);
  margin-bottom: var(--spacing-1);
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-dim);
  margin-bottom: var(--spacing-3);
}

.btn-refresh {
  min-width: 200rpx;
}

/* ========== 订单卡片 ========== */
.order-card {
  position: relative;
  padding: var(--spacing-2);
  margin-bottom: var(--spacing-2);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  transition: all var(--transition-base);
  overflow: hidden;
}

.order-card:active {
  transform: scale(0.98);
}

.order-card.urgent {
  border-left: 6rpx solid var(--warning);
}

.urgent-tag {
  position: absolute;
  top: var(--spacing-2);
  right: var(--spacing-2);
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, var(--warning) 0%, #F57C00 100%);
  color: #fff;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-2);
}

.order-title-section {
  flex: 1;
}

.order-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.order-type {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: rgba(74, 93, 78, 0.1);
  color: var(--green-main);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
}

.order-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--green-main);
  margin-left: var(--spacing-2);
}

/* ========== 订单内容 ========== */
.order-body {
  margin-bottom: var(--spacing-2);
  padding-bottom: var(--spacing-2);
  border-bottom: 1rpx solid rgba(74, 93, 78, 0.1);
}

.order-info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--spacing-1);
}

.order-info-row:last-of-type {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 26rpx;
  color: var(--text-dim);
  flex: 1;
  line-height: 1.5;
}

.info-distance {
  font-size: 24rpx;
  color: var(--green-main);
  margin-left: var(--spacing-1);
}

/* ========== 订单底部 ========== */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 24rpx;
  color: var(--text-dim);
}

.btn-grab {
  min-width: 200rpx;
  padding: 0 var(--spacing-3);
}

.btn-grab.grabbing {
  opacity: 0.6;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-3);
}

.loading-icon {
  font-size: 48rpx;
  margin-bottom: var(--spacing-1);
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-dim);
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 没有更多 ========== */
.no-more-state {
  padding: var(--spacing-3);
  text-align: center;
}

.no-more-text {
  font-size: 26rpx;
  color: var(--text-dim);
}
